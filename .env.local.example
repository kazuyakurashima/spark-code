# Anthropic API key — get one at https://console.anthropic.com
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored; this example file is tracked.
ANTHROPIC_API_KEY=

# --- Supabase ---
# Project: spark_code
# Dashboard → Project Settings → API Keys からコピーして貼る
# - anon (publishable) → NEXT_PUBLIC_SUPABASE_ANON_KEY
# - service_role (secret) → SUPABASE_SERVICE_ROLE_KEY (絶対にクライアントに渡さない)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
